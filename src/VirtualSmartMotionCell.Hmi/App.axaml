<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="VirtualSmartMotionCell.Hmi.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Button.command">
      <Setter Property="MinWidth" Value="96" />
      <Setter Property="Margin" Value="4" />
      <Setter Property="Padding" Value="13,8" />
    </Style>
    <Style Selector="Button.command.accent">
      <Setter Property="Background" Value="#176ca3" />
    </Style>
    <Style Selector="Button.command.danger">
      <Setter Property="Background" Value="#8d3036" />
    </Style>
    <Style Selector="Button.jog">
      <Setter Property="MinWidth" Value="150" />
      <Setter Property="MinHeight" Value="64" />
      <Setter Property="Margin" Value="5" />
      <Setter Property="FontSize" Value="19" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="#18232f" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="18" />
      <Setter Property="Margin" Value="6" />
    </Style>
    <Style Selector="Border.metric">
      <Setter Property="Background" Value="#16202b" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="14" />
      <Setter Property="Margin" Value="6" />
    </Style>
  </Application.Styles>
</Application>
