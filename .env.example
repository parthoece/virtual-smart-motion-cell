VSMC_URLS=http://0.0.0.0:8080
VSMC_DATA_DIR=./runtime-data
VSMC_SIMULATION_PERIOD_MS=10
VSMC_STATE_PUBLISH_PERIOD_MS=50
VSMC_CHECKPOINT_PERIOD_MS=1000
VSMC_ALLOW_REMOTE_COMMANDS=false
VSMC_MOTION_ADAPTER=simulated
VSMC_REPLAY_PATH=config/replay/motion-replay.json
VSMC_Mes__Mode=Http
VSMC_Mes__BaseUrl=http://localhost:8090/
VSMC_Mes__PollOrders=true
VSMC_OpcUa__Enabled=true
VSMC_OpcUa__Endpoint=opc.tcp://localhost:4840/vsmc
